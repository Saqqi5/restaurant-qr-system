// firestore.rules
// ═══════════════════════════════════════════════════════════════
// FIRESTORE SECURITY RULES — TableQR
// ═══════════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isSuperAdmin() {
      return hasRole('super_admin');
    }

    function isGeneralAdmin(restaurantId) {
      return isAuthenticated() &&
        getUserData().role == 'general_admin' &&
        getUserData().restaurant_id == restaurantId;
    }

    function isStaff(restaurantId) {
      return isAuthenticated() &&
        getUserData().restaurant_id == restaurantId &&
        getUserData().role in ['general_admin', 'kitchen', 'cash_counter', 'server'];
    }

    function isKitchen(restaurantId) {
      return isAuthenticated() &&
        getUserData().role == 'kitchen' &&
        getUserData().restaurant_id == restaurantId;
    }

    function isCashCounter(restaurantId) {
      return isAuthenticated() &&
        getUserData().role == 'cash_counter' &&
        getUserData().restaurant_id == restaurantId;
    }

    function isOrderStatusValid(status) {
      return status in ['pending', 'confirmed', 'preparing', 'ready', 'served', 'paid', 'cancelled'];
    }

    function isPaymentStatusValid(status) {
      return status in ['unpaid', 'paid'];
    }

    function isValidOrderCreate() {
      return request.resource.data.keys().hasAll([
          'id', 'table_number', 'items', 'status', 'total',
          'payment_status', 'payment_method', 'created_at',
          'updated_at', 'estimated_ready', 'notes', 'created_by'
        ])
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.table_number is int
        && request.resource.data.table_number >= 1
        && request.resource.data.table_number <= 500
        && request.resource.data.total is number
        && request.resource.data.total >= 0
        && request.resource.data.status == 'pending'
        && request.resource.data.payment_status == 'unpaid'
        && request.resource.data.notes is string
        && request.resource.data.notes.size() <= 300
        && request.resource.data.created_by is string;
    }

    function isOrderUpdateAllowed(restaurantId) {
      return isSuperAdmin() ||
        isGeneralAdmin(restaurantId) ||
        isKitchen(restaurantId) ||
        isCashCounter(restaurantId);
    }

    // ── Users ─────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || isSuperAdmin()
      );
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || request.auth.uid == userId;
      allow delete: if isSuperAdmin();
    }

    // ── Restaurants ───────────────────────────────────────────
    match /restaurants/{restaurantId} {
      // Anyone can read a restaurant (needed for customer menu)
      allow read: if true;

      // Only super admin can create/delete restaurants
      allow create, delete: if isSuperAdmin();

      // Super admin or the restaurant's general admin can update
      allow update: if isSuperAdmin() || isGeneralAdmin(restaurantId);

      // ── Menu Items ──────────────────────────────────────────
      match /menu/{itemId} {
        // Anyone can read menu items (for customer ordering)
        allow read: if true;

        // Only general admin or super admin can write
        allow write: if isSuperAdmin() || isGeneralAdmin(restaurantId);
      }

      // ── Orders ──────────────────────────────────────────────
      match /orders/{orderId} {
        // Customers can create orders (unauthenticated), but only if payload is valid
        allow create: if isValidOrderCreate();

        // Staff can read all orders for their restaurant
        allow read: if isStaff(restaurantId) || isSuperAdmin();

        // Staff status/payment updates with constrained values
        allow update: if isOrderUpdateAllowed(restaurantId)
          && isOrderStatusValid(request.resource.data.status)
          && isPaymentStatusValid(request.resource.data.payment_status)
          && request.resource.data.total == resource.data.total
          && request.resource.data.items == resource.data.items
          && request.resource.data.table_number == resource.data.table_number;

        // Only super admin can delete orders
        allow delete: if isSuperAdmin();
      }
    }

    // ── Domain Mappings ───────────────────────────────────────
    match /domain_mappings/{domain} {
      allow read: if true; // needed for domain resolution
      allow write: if isSuperAdmin();
    }
  }
}
