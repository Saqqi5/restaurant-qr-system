{
  "name": "tableqr-restaurant-saas",
  "version": "1.0.0",
  "description": "Multi-tenant QR-based restaurant ordering system",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:standalone": "VITE_DEPLOYMENT_MODE=standalone vite build",
