# ═══════════════════════════════════════════
# TABLEQR — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in values
# ═══════════════════════════════════════════

# ── Firebase Configuration ──────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxx

# ── Deployment Mode ─────────────────────────
# Options: "saas" (default) | "standalone"
VITE_DEPLOYMENT_MODE=saas

# ── Standalone Mode Only ─────────────────────
# Set this when deploying for a single restaurant (white-label)
# VITE_RESTAURANT_ID=your_restaurant_id_here

# ── App URL (for QR code generation) ────────
VITE_APP_URL=https://yourdomain.com
